# Copy this file to `.env` and fill in real values. `.env` is git-ignored — it holds
# secrets and must never be committed.

# Where the database lives.
#   Local development (no Postgres needed): sqlite:///./ludo_dev.db
#   Production (Neon/Supabase): postgresql+psycopg://user:password@host/dbname
DATABASE_URL=sqlite:///./ludo_dev.db

# Secret used to sign JWTs. Anyone who knows this can forge logins, so in production
# it must be a long random string (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
JWT_SECRET=change-me-to-a-long-random-string

# The admin account created automatically on first startup (only if no admin exists yet).
ADMIN_USERNAME=admin
ADMIN_TEMP_PASSWORD=change-me-on-first-login

# Set to "true" in production so the auth cookie is only sent over HTTPS.
COOKIE_SECURE=false
